    </style>
</head>
<body>
    <h1>Daily Triage Dashboard</h1>
    <p class="updated">Updated: {now}</p>

    <h2>New Action Items ({len(new_items)})</h2>
    {"<table><tr><th></th><th>Meeting</th><th>Action Item</th></tr>" + new_rows + "</table>" if new_items else '<p class="empty">No new action items</p>'}

    <h2>Jira Tickets</h2>
    <div class="tabs">
        <div class="tab active" onclick="switchTab('sprint')">
            Current: {sprint_name or 'None'} ({len(sprint_tickets)})
        </div>
        <div class="tab" onclick="switchTab('last-sprint')">
            Last: {last_sprint_name or 'None'} ({len(last_sprint_tickets)})
        </div>
        <div class="tab" onclick="switchTab('backlog')">
            Backlog ({len(backlog_tickets)})
        </div>
        <div class="tab" onclick="switchTab('all')">
            All Open ({len(tickets)})
        </div>
