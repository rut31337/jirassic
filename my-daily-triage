    <div id="tab-sprint" class="tab-content active">
        {sprint_table}
    </div>
    <div id="tab-last-sprint" class="tab-content">
        {last_sprint_table}
    </div>
    <div id="tab-backlog" class="tab-content">
        {backlog_table}
    </div>
    <div id="tab-all" class="tab-content">
        {all_table}
    </div>

    <h2>
        <span class="toggle" onclick="document.getElementById('triaged-section').classList.toggle('collapsed'); var a = this.querySelector('.arrow'); a.textContent = a.textContent === '\u25B6' ? '\u25BC' : '\u25B6'">
            Triaged Action Items ({len(triaged_items)})
            <span class="arrow">&#9654;</span>
        </span>
    </h2>
    <div id="triaged-section" class="collapsed">
    {"<h3><span class='toggle' onclick='document.getElementById(\"jira-items\").classList.toggle(\"collapsed\"); this.querySelector(\".arrow\").textContent = this.querySelector(\".arrow\").textContent === \"▶\" ? \"▼\" : \"▶\"'>Linked to Jira (" + str(len([v for v in triaged_items.values() if v.get('status') == 'jira'])) + ") <span class=\"arrow\">▶</span></span></h3><div id=\"jira-items\" class=\"collapsed\"><table><tr><th>Ticket</th><th>Meeting</th><th>Action Item</th></tr>" + triaged_jira_rows + "</table></div>" if triaged_jira_rows else ""}
    {"<h3><span class='toggle' onclick='document.getElementById(\"skip-items\").classList.toggle(\"collapsed\"); this.querySelector(\".arrow\").textContent = this.querySelector(\".arrow\").textContent === \"▶\" ? \"▼\" : \"▶\"'>Skipped / Ignored (" + str(len([v for v in triaged_items.values() if v.get('status') != 'jira'])) + ") <span class=\"arrow\">▶</span></span></h3><div id=\"skip-items\" class=\"collapsed\"><table><tr><th>Status</th><th>Meeting</th><th>Action Item</th></tr>" + triaged_skip_rows + "</table></div>" if triaged_skip_rows else ""}
    {"" if triaged_items else '<p class="empty">No triaged items yet</p>'}
    </div>

    <script>
    function switchTab(name) {{
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        event.target.classList.add('active');
    }}
    </script>
</body>
</html>"""

    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with open(DASHBOARD_FILE, "w") as f:
        f.write(html)
    return str(DASHBOARD_FILE)


def interactive_triage(new_items, state):
    """Interactively triage new action items."""
    if not new_items:
        return

    print()
    print("=== Triage New Items ===")
    print("For each item: [s]kip, [j]ira (enter ticket key), [d]one, [enter] to skip for now")
    print()

    for meeting, date, text, h in new_items:
        print(f"  [{meeting}]")
        print(f"  {text}")
        try:
            choice = input("  > ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not choice:
            continue
        elif choice == "s":
            state["triaged"][h] = {
                "text": text, "meeting": meeting,
                "status": "skip", "triaged": datetime.now().isoformat(),
            }
        elif choice == "d":
            state["triaged"][h] = {
                "text": text, "meeting": meeting,
                "status": "done", "triaged": datetime.now().isoformat(),
            }
        elif choice.startswith("j"):
            ticket = choice[1:].strip().upper() if len(choice) > 1 else ""
            if not ticket:
                ticket = input("  Ticket key: ").strip().upper()
            state["triaged"][h] = {
                "text": text, "meeting": meeting,
                "status": "jira", "ticket": ticket,
                "triaged": datetime.now().isoformat(),
            }
        print()

    save_state(state)


def main():
    state = load_state()

    # Gather data
    action_data = get_action_items()
    tickets = get_jira_tickets()

    # Flatten action items and find new ones
    all_items = []
    for meeting in action_data:
        for item_text in meeting["items"]:
            h = item_hash(item_text)
            all_items.append((meeting["meeting"], meeting["date"], item_text, h))

    new_items = [(m, d, t, h) for m, d, t, h in all_items if h not in state["triaged"]]
    triaged = state["triaged"]

    # Welcome mode — just print summary
    if WELCOME:
        parts = []
        if new_items:
            parts.append(f"{len(new_items)} new action item{'s' if len(new_items) != 1 else ''}")
        if tickets:
            parts.append(f"{len(tickets)} open ticket{'s' if len(tickets) != 1 else ''}")
        if parts:
            print(f"Daily triage: {', '.join(parts)}")
            if new_items:
                for m, d, t, h in new_items:
                    print(f"  - [{m.replace('Notes: ', '')}] {t[:100]}{'...' if len(t) > 100 else ''}")
        else:
            print("Daily triage: all clear")
        return

    # Full display
    print("=" * 60)
    print("  DAILY TRIAGE")
    print("=" * 60)

    if new_items:
        print(f"\n--- New Action Items ({len(new_items)}) ---\n")
        for i, (meeting, date, text, h) in enumerate(new_items, 1):
            print(f"  {i}. [{meeting}]")
            print(f"     {text}")
            print()
    else:
        print("\n  No new action items.\n")

    if tickets:
        # Group tickets
        epics = {}
        epic_info = {}
        standalone = []
        for t in tickets:
            if t["type"] == "Epic":
                epic_info[t["key"]] = t
                epics.setdefault(t["key"], [])
            elif t["parent"]:
                epics.setdefault(t["parent"], []).append(t)
            else:
                standalone.append(t)

        print(f"--- Open Jira Tickets ({len(tickets)}) ---\n")
        for key, children in epics.items():
            info = epic_info.get(key)
            if info:
                print(f"  {info['key']}  [{info['status']}]  {info['summary']}")
            else:
                print(f"  {key}  (epic)")
            for c in children:
                print(f"    {c['key']}  [{c['status']}]  {c['summary']}")
        if standalone:
            print(f"\n  Standalone:")
            for t in standalone:
                print(f"    {t['key']}  [{t['status']}]  {t['summary']}")
        print()

    # Notifications
    if NOTIFY:
        if new_items:
            msg = f"{len(new_items)} new action item{'s' if len(new_items) != 1 else ''}, {len(tickets)} open tickets"
            macos_notify("Daily Triage", msg)
        else:
            macos_notify("Daily Triage", f"All clear. {len(tickets)} open tickets.")

    # HTML dashboard
    if HTML:
        path = generate_html(new_items, triaged, tickets)
        print(f"Dashboard: file://{path}")

    # Interactive triage
    if INTERACTIVE and new_items and sys.stdin.isatty():
        interactive_triage(new_items, state)


if __name__ == "__main__":
    main()
