#!/usr/bin/env python3
"""Extracts your action items from Gemini meeting notes emails.

Usage: my-action-items [DAYS]

Set your name once:
    export GWS_NAME="Your Name"
    # Add to your ~/.zshrc or ~/.bashrc to make it permanent

Examples:
    my-action-items          # last 7 days
    my-action-items 14       # last 14 days
"""

import json
import os
import subprocess
import sys

NAME = os.environ.get("GWS_NAME")
if not NAME:
    print("Error: GWS_NAME environment variable is not set.")
    print()
    print("Set it once in your shell profile (~/.zshrc or ~/.bashrc):")
    print()
    print('  export GWS_NAME="Your Name"')
    print()
    print("Then restart your terminal or run: source ~/.zshrc")
    sys.exit(1)

DAYS = int(sys.argv[1]) if len(sys.argv) > 1 else 7


def gws(*args):
    result = subprocess.run(
        ["gws", *args],
        capture_output=True, text=True,
    )
    return result.stdout


# Get message IDs from Gemini meeting notes that mention your name
query = f'from:gemini-notes@google.com newer_than:{DAYS}d "{NAME}"'
triage_json = gws("gmail", "+triage", "--query", query, "--max", "50", "--format", "json")

if not triage_json.strip():
    print(f"No action items found in the last {DAYS} days.")
    sys.exit(0)

messages = json.loads(triage_json).get("messages", [])
found = False

for msg in messages:
    msg_json = gws("gmail", "+read", "--id", msg["id"], "--format", "json")
    if not msg_json.strip():
        continue

    email = json.loads(msg_json)
    text = email.get("body_text", "")
    subject = email.get("subject", "")
    date = email.get("date", "")

    start = text.find("Suggested next steps")
    end = text.find("Meeting records", start if start >= 0 else 0)

    if start < 0 or end < 0:
        continue

    section = text[start:end]

    # Split action items on blank lines, then join continuation lines
    items = []
    current = []
    for line in section.splitlines():
        stripped = line.strip()
        if not stripped or stripped == "Suggested next steps":
            if current:
                full = " ".join(current)
                if NAME in full:
                    items.append(full)
                current = []
        else:
            current.append(stripped)
    if current:
        full = " ".join(current)
        if NAME in full:
            items.append(full)

    if items:
        found = True
        print(f"{subject} ({date})")
        for item in items:
            print(f"  - {item}")
        print()

if not found:
    print(f"No action items found in the last {DAYS} days.")
