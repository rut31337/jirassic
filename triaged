#!/usr/bin/env bash
# Manage the Daily Triage Dashboard server
# Usage: triaged start|stop|restart|status|open

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")")" && pwd)"
PID_FILE="$HOME/.config/daily-triage/server.pid"
LOG_FILE="$HOME/.config/daily-triage/server.log"
PORT=31337

mkdir -p "$HOME/.config/daily-triage"

start() {
  if is_running; then
    echo "Already running (PID $(cat "$PID_FILE"))"
    echo "Dashboard: http://localhost:$PORT"
    return
  fi

  cd "$SCRIPT_DIR"

  # Install deps if needed
  if [ ! -d node_modules ]; then
    echo "Installing dependencies..."
    npm install --silent 2>/dev/null
  fi

  # Source env for secrets
  [ -f "$HOME/.env" ] && export $(grep -v '^#' "$HOME/.env" | xargs)
  [ -f "$HOME/.zshrc" ] && eval "$(grep '^export GWS_NAME' "$HOME/.zshrc")"

  export TRIAGE_PROJECT="${TRIAGE_PROJECT:-GPTEINFRA}"
  export TRIAGE_DAYS="${TRIAGE_DAYS:-7}"

  nohup node server.js > "$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  echo "Started (PID $!)"
  echo "Dashboard: http://localhost:$PORT"
  echo "Logs: $LOG_FILE"
}

stop() {
  if ! is_running; then
    echo "Not running"
    return
  fi
  local pid=$(cat "$PID_FILE")
  kill "$pid" 2>/dev/null
  rm -f "$PID_FILE"
  echo "Stopped (PID $pid)"
}

restart() {
  stop
  sleep 1
  start
}

status() {
  if is_running; then
    echo "Running (PID $(cat "$PID_FILE"))"
    echo "Dashboard: http://localhost:$PORT"
  else
    echo "Not running"
  fi
}

is_running() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

open_dashboard() {
  if ! is_running; then
    start
    sleep 2
  fi
  open "http://localhost:$PORT"
}

case "${1:-}" in
  start)   start ;;
  stop)    stop ;;
  restart) restart ;;
  status)  status ;;
  open)    open_dashboard ;;
  *)
    echo "Usage: triaged {start|stop|restart|status|open}"
    echo ""
    echo "Commands:"
    echo "  start    Start the dashboard server"
    echo "  stop     Stop the dashboard server"
    echo "  restart  Restart the dashboard server"
    echo "  status   Show if the server is running"
    echo "  open     Start (if needed) and open in browser"
    ;;
esac
